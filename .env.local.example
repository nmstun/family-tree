# Supabase の Project Settings > API から値を取得してコピーしてください。
# ローカル開発では `supabase start` 実行後に表示される値を使います。

# ローカル開発の場合の例:
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=（`supabase start` の出力に表示される anon key）

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role（secret）キー。未登録メールアドレスへの招待（管理者API）で使用。
# クライアントに絶対に公開してはいけない（NEXT_PUBLIC_ を付けないこと）。
# 本番（Vercel）では Production 環境の環境変数として登録すること。
SUPABASE_SERVICE_ROLE_KEY=
